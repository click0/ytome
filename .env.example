# YouTube Data API v3 key
# Получить: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Путь к хранилищу файлов
# Windows: C:\Users\YourName\youtube-archive\storage
# Linux/Mac: /home/yourname/youtube-archive/storage
STORAGE_PATH=./storage

# Путь к SQLite базе данных
DB_PATH=./storage/archive.db

# Транспорт MCP: "stdio" (локально) или "http" (сервер)
MCP_TRANSPORT=stdio

# Порт HTTP-сервера (только если MCP_TRANSPORT=http)
MCP_PORT=3000

# Интервал проверки новых видео (cron формат)
# По умолчанию: каждые 2 часа
CHECK_INTERVAL=0 */2 * * *

# Максимум видео на канал при первой синхронизации
INITIAL_FETCH_LIMIT=50

# Скачивать thumbnails автоматически (true/false)
AUTO_DOWNLOAD_THUMBNAILS=true

# ─── ПРОКСІ ────────────────────────────────────────
# Режим: disabled | single | rotation | fallback
# Можна змінити через MCP-інструмент proxy_set_mode
PROXY_MODE=disabled

# Проксі додаються через MCP: proxy_add
# Приклади URL:
#   http://host:port
#   http://user:password@host:port
#   socks5://host:1080
#   socks5://user:password@host:1080

# Шлях до yt-dlp (якщо не в PATH)
# Windows: YTDLP_BIN=C:\\Tools\\yt-dlp.exe
YTDLP_BIN=yt-dlp

# ─── AI ПРОВАЙДЕРИ ────────────────────────────────
# Режим балансера: priority | cost | roundrobin
#
#   priority   — фіксований пріоритет за складністю задачі
#   cost       — автоматично вибирає найдешевший провайдер (рекомендовано)
#   roundrobin — рівномірно розподіляє запити між всіма активними
#
BALANCER_MODE=cost

# Claude (Anthropic) — complex / critical задачі
ANTHROPIC_API_KEY=

# Ollama — локально, безкоштовно (https://ollama.ai)
# Запуск: ollama serve && ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_ENABLED=true

# Groq — хмара, безкоштовний tier (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter — 100+ моделей, є безкоштовні (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# LM Studio — локально (https://lmstudio.ai)
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=local-model
LMSTUDIO_ENABLED=false

# ─── MCP HTTP СЕРВЕР ───────────────────────────────
MCP_HTTP_PORT=3000
# MCP_HOST=0.0.0.0       # розкоментувати для LAN доступу
# MCP_API_KEY=my-secret  # токен для захисту endpoint

# ─── AI PROXY URL (зовнішній роутер) ───────────────
# Якщо встановлено — всі AI запити йдуть через цей URL.
# Внутрішній балансер використовується як fallback.
#
# claude-code-router:  AI_PROXY_URL=http://localhost:3456
# olla:                AI_PROXY_URL=http://localhost:40114/olla/openai
# OmniRoute/NadirClaw: AI_PROXY_URL=http://localhost:8402
# Ollama на LAN ПК:    AI_PROXY_URL=http://192.168.1.50:11434
# Self-hosted VPS:     AI_PROXY_URL=https://ai.myserver.com
#
AI_PROXY_URL=
AI_PROXY_API_KEY=     # Bearer token якщо роутер вимагає авторизацію
AI_PROXY_MODEL=       # Модель для проксі (порожньо = auto)
