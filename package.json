{
  "name": "ytome",
  "version": "0.85.0",
  "description": "Independent YouTube archive & MCP server for Claude",
  "main": "dist/mcp/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/mcp/index.ts",
    "start:local": "node dist/mcp/index.js",
    "start:server": "node dist/mcp/server-http.js",
    "db:init": "node dist/db/init.js",
    "scheduler": "node dist/scheduler/index.js",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "https-proxy-agent": "^9.1.0",
    "node-cron": "^4.6.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socks-proxy-agent": "^10.1.0",
    "youtube-transcript-plus": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
